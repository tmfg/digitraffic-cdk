  <xs:complexType name="AlternativeFuelsRefillPoint">
    <xs:annotation>
      <xs:documentation>A refill point for alternative fules like CNG,LNG,LPG,biogas or hydrogen (liquid or gaseous).</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="aegi:RefillPoint">
        <xs:sequence>
          <xs:element name="connector" type="aegi:_GasConnectorTypeEnum" minOccurs="0" maxOccurs="unbounded">
            <xs:annotation>
              <xs:documentation>Information on the alternative fuels type connector at the refill point.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="otherConnector" type="com:String" minOccurs="0" maxOccurs="unbounded">
            <xs:annotation>
              <xs:documentation>Any other type of alternative fuels connector.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="hydrogenProcessProtocol" type="aegi:_HydrogenFuellingProcessProtocolEnum" minOccurs="0" maxOccurs="1">
            <xs:annotation>
              <xs:documentation>Information on which protocol is used for the fuelling process for hydrogen.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="renewableSourcesRatio" type="com:Percentage" minOccurs="0" maxOccurs="1">
            <xs:annotation>
              <xs:documentation>Percentage of renewable energy sources for the alternative fluel, to be indicated in %.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="pressure" type="aegi:Bar" minOccurs="0" maxOccurs="1">
            <xs:annotation>
              <xs:documentation>The pressure which is used for gaseous fuel.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="_alternativeFuelsRefillPointExtension" type="com:_ExtensionType" minOccurs="0" />
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>
