        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="onCompanySite">
        <xs:annotation>
          <xs:documentation>The energy infrastructure site is located on a company site.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="other">
        <xs:annotation>
          <xs:documentation>Other types of energy infrastructure sites.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="_extended" />
    </xs:restriction>
  </xs:simpleType>
  <xs:complexType name="EnergyInfrastructureStation">
    <xs:annotation>
      <xs:documentation>A collection of associated refill points (which can be of different type). An example would be a fuel dispenser that serves different types of fuel. Often the vehicle space of the station is shared between the different refill points.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="afac:Facility">
        <xs:sequence>
          <xs:element name="totalMaximumPower" type="aegi:Watt" minOccurs="0" maxOccurs="1">
            <xs:annotation>
              <xs:documentation>The total maximum power of the station.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="authenticationAndIdentificationMethods" type="aegi:_AuthenticationAndIdentificationEnum" minOccurs="0" maxOccurs="unbounded">
            <xs:annotation>
              <xs:documentation>Information on what methods of identification and/or authentication are accepted.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="numberOfRefillPoints" type="com:NonNegativeInteger" minOccurs="0" maxOccurs="1">
            <xs:annotation>
              <xs:documentation>Number of refill points that can be used at the same time in this energy infrastructure station.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="userInterfaceLanguage" type="com:Language" minOccurs="0" maxOccurs="unbounded">
            <xs:annotation>
              <xs:documentation>Languages, in which a user interface is available.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="renewableSources" type="com:Boolean" minOccurs="0" maxOccurs="1">
            <xs:annotation>
              <xs:documentation>Specifies, if the energy sources (e.g. hydrogen or liquid methane) are 100 % renewable in accordance with rules established under Directive (EU) 2018/2001 and relevant secondary legislation (EU Guarantee of Origin (GO) scheme).</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="energyDistributor" type="afac:Organisation" minOccurs="0">
            <xs:annotation>
              <xs:documentation>The distributor of the energy.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="mobilityServiceProvider" type="afac:Organisation" minOccurs="0" maxOccurs="unbounded">
            <xs:annotation>
              <xs:documentation>Mobility service providers offering contract-based recharging</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="roamingPlatform" type="afac:Organisation" minOccurs="0" maxOccurs="unbounded">
            <xs:annotation>
              <xs:documentation>Supported roaming platforms</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="hydrogen" type="aegi:Hydrogen" minOccurs="0" />
          <xs:element name="serviceType" type="aegi:ServiceType" minOccurs="0" maxOccurs="unbounded">
            <xs:annotation>
              <xs:documentation>Specify the type of service available at the EnergyInfrastructureStation.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="refillPoint" type="aegi:RefillPoint" minOccurs="0" maxOccurs="unbounded">
            <xs:annotation>
              <xs:documentation>Specifications of refill points at a charging station. Note that the refillPointIndex must be unique within the complete site!</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="energyProduct" type="aegi:EnergyProduct" minOccurs="0" maxOccurs="unbounded" />
          <xs:element name="_energyInfrastructureStationExtension" type="com:_ExtensionType" minOccurs="0" />
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>
  <xs:complexType name="EnergyInfrastructureStationStatus">
    <xs:annotation>
      <xs:documentation>Dynamic information on the status of the station.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="afac:FacilityStatus">
        <xs:sequence>
          <xs:element name="isAvailable" type="com:Boolean" minOccurs="0" maxOccurs="1">
            <xs:annotation>
              <xs:documentation>Information whether the specific station is available or not. It might be unavailable for example because of a fault, damage or maintenance. It does not inform, if the corresponding refill points are currently occupied or not.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="limitedHydrogenAmount" type="com:Boolean" minOccurs="0" maxOccurs="1">
            <xs:annotation>
              <xs:documentation>Indication about limited amount of hydrogen available (less than 100 kg) in the refuelling station.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="refillPointStatus" type="aegi:RefillPointStatus" minOccurs="0" maxOccurs="unbounded">
            <xs:annotation>
              <xs:documentation>Specify the status of a refill point with dynamic information.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="serviceType" type="aegi:ServiceType" minOccurs="0" maxOccurs="unbounded">
            <xs:annotation>
              <xs:documentation>The service type for the station. If no period is given, the currently available service is meant.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="energyRateUpdate" type="aegi:EnergyRateUpdate" minOccurs="0" maxOccurs="unbounded" />
          <xs:element name="_energyInfrastructureStationStatusExtension" type="com:_ExtensionType" minOccurs="0" />
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>
  <xs:complexType name="EnergyInfrastructureStatusPublication">
    <xs:annotation>
      <xs:documentation>Dynamic information on the status of energy supplying sites.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="com:PayloadPublication">
        <xs:sequence>
          <xs:element name="tableReference" type="aegi:_EnergyInfrastructureTableVersionedReference" minOccurs="0" maxOccurs="unbounded">
            <xs:annotation>
              <xs:documentation>Reference to static tables containing the sites referenced in this publication.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="headerInformation" type="com:HeaderInformation" minOccurs="0" />
          <xs:element name="energyInfrastructureSiteStatus" type="aegi:EnergyInfrastructureSiteStatus" minOccurs="0" maxOccurs="unbounded" />
          <xs:element name="_energyInfrastructureStatusPublicationExtension" type="com:_ExtensionType" minOccurs="0" />
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>
  <xs:complexType name="EnergyInfrastructureTable">
    <xs:annotation>
      <xs:documentation>A table of sites where vehicles can be supplied with energy.</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="tableName" type="com:String" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>The name of the Energy Infrastructure Table.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="energyInfrastructureSite" type="aegi:EnergyInfrastructureSite" maxOccurs="unbounded" />
      <xs:element name="_energyInfrastructureTableExtension" type="com:_ExtensionType" minOccurs="0" />
    </xs:sequence>
    <xs:attribute name="id" type="xs:string" use="required" />
    <xs:attribute name="version" type="xs:string" use="required" />
  </xs:complexType>
  <xs:complexType name="EnergyInfrastructureTablePublication">
    <xs:annotation>
      <xs:documentation>A publication of static information on the infrastructure for vehicle energy supply.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="com:PayloadPublication">
        <xs:sequence>
          <xs:element name="headerInformation" type="com:HeaderInformation" minOccurs="0" />
          <xs:element name="energyInfrastructureTable" type="aegi:EnergyInfrastructureTable" maxOccurs="unbounded" />
          <xs:element name="_energyInfrastructureTablePublicationExtension" type="com:_ExtensionType" minOccurs="0" />
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>
  <xs:complexType name="EnergyPrice">
    <xs:annotation>
      <xs:documentation>A price definition for energy refueling. All prices (of a rate) with the same group index belong together (for example base price AND price per kWh). Prices with a different group index are alternative to each other (for example price per minute OR flat r</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="priceGroupIndex" type="com:NonNegativeInteger" minOccurs="1" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>All prices (of a rate) with the same group index belong together (for example base price AND price per kWh). Prices with a different group index are alternative to each other (for example price per minute OR flat rate instead).</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="priceType" type="aegi:_PriceTypeEnum" minOccurs="1" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>The type of price for the energy supply.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="value" type="afac:AmountOfMoney" minOccurs="1" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>The price for the energy according to the price type.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="priceCap" type="afac:AmountOfMoney" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>An upper cap for this price which will be charged at maximum.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="taxIncluded" type="com:Boolean" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>[TRUE] Indication that tax to be applied is included [FALSE] indicates that the tax is added additionally to the total.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="taxRate" type="com:Percentage" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>The percentage rate of tax to be applied.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="additionalInformation" type="com:MultilingualString" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>Free text field for additional information regarding the price.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="overallPeriod" type="com:OverallPeriod" minOccurs="0" />
      <xs:element name="timeBasedApplicability" type="aegi:TimeBasedApplicability" minOccurs="0" />
      <xs:element name="energyBasedApplicability" type="aegi:EnergyBasedApplicability" minOccurs="0" />
      <xs:element name="_energyPriceExtension" type="com:_ExtensionType" minOccurs="0" />
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="EnergyProduct">
    <xs:annotation>
      <xs:documentation>Specification of an energy product that is offered. It can be applied to all types of energy sources.</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="energyProductName" type="com:MultilingualString" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>A name for this energy product.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="isGreenEnergy" type="com:Boolean" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>True if 100% from regenerative sources (CO2 and nuclear waste is zero).</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="energyRateByReference" type="aegi:_EnergyRateReference" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>Specifies one ore more rates for this type of energy by reference to exisiting EnergyRate specification.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="energyProductInformation" type="com:Url" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>Further information on this energy product provided by a web link.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="renewableEnergyEvidence" type="com:Url" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>Proofs on the sources of renewable energy for this energy product provided by a web link.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="mobilityServiceProvider" type="afac:Organisation" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>Mobility service providers offering contract-based recharging</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="energyRate" type="aegi:EnergyRate" minOccurs="0" maxOccurs="unbounded" />
      <xs:element name="_energyProductExtension" type="com:_ExtensionType" minOccurs="0" />
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="EnergyRate">
    <xs:annotation>
      <xs:documentation>A rate dedicated for the energy product.</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="ratePolicy" type="aegi:_RatePolicyEnum" minOccurs="1" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>Indication if contract based or ad hoc price.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="lastUpdated" type="com:DateTime" minOccurs="1" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>The date/time at which this information was last updated.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="applicableCurrency" type="afac:CurrencyCode" minOccurs="1" maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>A general information on the applicable monetary currency.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="rateName" type="com:MultilingualString" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>A name for this rate, for example the name of the specific energy contract.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="combinationWithParkingFee" type="com:Boolean" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>Indicates whether vehicle charging and parking are included in one combined fee.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="maximumDeliveryFee" type="afac:AmountOfMoney" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>A maximum delivery fee.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="minimumDeliveryFee" type="afac:AmountOfMoney" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>A minimum delivery fee.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="discount" type="com:Percentage" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>Discount indicated in %.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="additionalInformation" type="com:MultilingualString" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>Free text field for additional information regarding the energy rates.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="payment" type="afac:Payment" minOccurs="0" />
      <xs:element name="energyPrice" type="aegi:EnergyPrice" minOccurs="0" maxOccurs="unbounded" />
      <xs:element name="overallPeriod" type="com:OverallPeriod" minOccurs="0" />
      <xs:element name="_energyRateExtension" type="com:_ExtensionType" minOccurs="0" />
    </xs:sequence>
    <xs:attribute name="id" type="xs:string" use="required" />
  </xs:complexType>
  <xs:complexType name="EnergyRateUpdate">
    <xs:annotation>
      <xs:documentation>Updates a rate defined in the static part of the model.</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="lastUpdated" type="com:DateTime" minOccurs="1" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>The date/time at which this information was last updated.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="energyRateReference" type="aegi:_EnergyRateReference" minOccurs="1" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>Specifies the EnergyRate that is updated here.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="additionalInformation" type="com:MultilingualString" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>Free text field for additional information regarding the energy rates.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="energyPrice" type="aegi:EnergyPrice" minOccurs="0" maxOccurs="unbounded" />
      <xs:element name="_energyRateUpdateExtension" type="com:_ExtensionType" minOccurs="0" />
    </xs:sequence>
  </xs:complexType>
