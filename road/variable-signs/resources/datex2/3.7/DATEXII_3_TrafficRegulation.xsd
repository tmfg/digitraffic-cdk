  <xs:simpleType name="ConditionOperator">
    <xs:annotation>
      <xs:documentation>The logical operator to be used in a test of conditions.</xs:documentation>
    </xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="and">
        <xs:annotation>
          <xs:documentation>The AND logical operator – a logical operation to determine if all conditions in a test are TRUE.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="or">
        <xs:annotation>
          <xs:documentation>The OR logical operator – a logical operation to determine if any conditions in a test are TRUE.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="xor">
        <xs:annotation>
          <xs:documentation>The XOR logical operator - a logical operation that outputs true only when inputs differ (one is true, the other is false).</xs:documentation>
