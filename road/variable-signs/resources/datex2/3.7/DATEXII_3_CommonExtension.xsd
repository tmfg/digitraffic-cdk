  <xs:simpleType name="EuBodyworkCodeEnum">
    <xs:annotation>
      <xs:documentation>Bodywork codes according to REGULATION (EU) 2018/858.</xs:documentation>
    </xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="aa">
        <xs:annotation>
          <xs:documentation>Saloon - A vehicle defined in term 3.1.1.1 of international standard ISO 3833:1977, fitted with at least four side windows.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="ab">
        <xs:annotation>
          <xs:documentation>Hatchback - A saloon as defined in REGULATION (EU) 2018/858 Annex 1 Part C Ref. 2.1 with a hatch at the rear end of the vehicle.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="ac">
        <xs:annotation>
          <xs:documentation>Station wagon - A vehicle defined in term 3.1.1.4 of international standard ISO 3833:1977.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="ad">
        <xs:annotation>
          <xs:documentation>Coupé - A vehicle defined in term 3.1.1.5 of international standard ISO 3833:1977.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="ae">
        <xs:annotation>
          <xs:documentation>Convertible - A vehicle defined in terms No 3.1.1.6 of international standard ISO 3833:1977. However, a convertible may have no door.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="af">
        <xs:annotation>
          <xs:documentation>Multi-purpose - A vehicle other than AG and those mentioned in AA to AE in tended for carrying persons and their luggage or occasionally goods, in a single compartment.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="ag">
        <xs:annotation>
          <xs:documentation>Truck station wagon-Vehicle defined in term No 3.1.1.4.1 of ISO 3833:1977. The luggage compartment must be compl. sepated from the passenger compartment. And the ref. point of the driver's seating pos. must be min. 750mm above the surface supp. the veh.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="ba">
        <xs:annotation>
          <xs:documentation>Lorry - A vehicle that is designed and constructed exclusively or principally for conveying goods. It may also tow a trailer.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="bb">
        <xs:annotation>
          <xs:documentation>Van - A lorry with the compartment where the driver is located and cargo area within a single unit.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="bc">
        <xs:annotation>
          <xs:documentation>Tractor unit for semi-trailer - A towing vehicle that is designed and constructed exclusively or principally to tow semi-trailers.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="bd">
        <xs:annotation>
          <xs:documentation>Road tractor - A towing vehicle that is designed and constructed exclusively to tow trailers other than semi-trailers.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="be">
        <xs:annotation>
          <xs:documentation>Pick-up truck - A vehicle of a maximum mass not exceeding 3 500 kg in which the seating positions and the cargo area are not located in a single compartment.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="bx">
        <xs:annotation>
          <xs:documentation>Chassis-cab or chassis-cowl - An incomplete vehicle with just a cabin (complete or partial), chassis rails, power train, axles, which is intended to be completed with bodywork, customised to the needs of the transport operator.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="ca">
        <xs:annotation>
          <xs:documentation>Single-deck vehicle - A vehicle where the spaces provided for persons are arranged in a single level or in a way that they do not constitute two superimposed levels. </xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="cb">
        <xs:annotation>
          <xs:documentation>Double-deck vehicle - A vehicle defined in paragraph 2.1.6 of UN Regulation No 107.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="cc">
        <xs:annotation>
          <xs:documentation>Single-deck articulated vehicle - A vehicle defined in paragraph 2.1.3 of UN Regulation No 107 with a single deck.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="cd">
        <xs:annotation>
          <xs:documentation>Double-deck articulated vehicle - A vehicle defined in paragraph 2.1.3.1 of UN Regulation No 107.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="ce">
        <xs:annotation>
          <xs:documentation>Low-floor single-deck vehicle - A vehicle defined in paragraph 2.1.4 of UN Regulation No 107 with a single deck.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="cf">
        <xs:annotation>
          <xs:documentation>Low-floor double-deck vehicle - A vehicle defined in paragraph 2.1.4 of UN Regulation No 107 with a double deck.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="cg">
        <xs:annotation>
          <xs:documentation>Articulated low-floor single-deck vehicle - A vehicle that combines the technical features of codes CC and CE.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="ch">
        <xs:annotation>
          <xs:documentation>Articulated low-floor double-deck vehicle - A vehicle that combines the technical features of codes CD and CF.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="ci">
        <xs:annotation>
          <xs:documentation>Open top single deck vehicle - A vehicle with partial roof or without roof.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="cj">
        <xs:annotation>
          <xs:documentation>Open top double deck vehicle - A vehicle without roof over all or part of its upper deck.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="cx">
        <xs:annotation>
          <xs:documentation>Bus chassis - An incomplete vehicle with just chassis rails or tube assembly, power train, axles, that is intended to be completed with bodywork, customised to the needs of the transport operator.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="da">
        <xs:annotation>
          <xs:documentation>Semi-trailer-Trailer that is des. and constr. to be coupled to a tractor unit or converter dolly and to impose a subst. vertical load on the towing vehicle or converter dolly. The coupling for a vehicle comb. shall consist of a king pin and a fifth wheel.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="db">
        <xs:annotation>
          <xs:documentation>Drawbar trailer-Trailer having at least two axles, with at least one is a steered axle:(a)equipped with a towing device which can move vertically (in relation to trailer); (b)that transmits less than 100daN as static vertical load to the towing vehicle.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="dc">
        <xs:annotation>
          <xs:documentation>Centre-axle trailer- see definition in REGULATION (EU) 2018/858 Annex 1 Part C Ref. 5.3.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="de">
        <xs:annotation>
          <xs:documentation>Rigid drawbar trailer- see definition in REGULATION (EU) 2018/858 Annex 1 Part C Ref. 5.4.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="_extended" />
    </xs:restriction>
  </xs:simpleType>
