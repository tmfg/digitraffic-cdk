  <xs:complexType name="AllFaultsOfSingleDevice">
    <xs:annotation>
      <xs:documentation>A collection of all current faults of a service fulfilled by a single device. An empty structure means that there are no faults reported for the device.</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="operatingProperlySince" type="com:DateTime" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>Time, since when the device is working properly (without fault).</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="deviceReference" type="fst:DeviceReference" />
      <xs:element name="deviceFault" type="fst:DeviceFault" minOccurs="0" maxOccurs="unbounded" />
      <xs:element name="_allFaultsOfSingleDeviceExtension" type="com:_ExtensionType" minOccurs="0" />
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="CatalogueInformation">
    <xs:annotation>
      <xs:documentation>A reference to specific additional information by means of a predefined element out of a catalogue. The type of reference information depends on the data structure this class is aggregated to.</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="catalogueReferenceByOID" type="fst:ObjectIdentifier" minOccurs="1" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>The reference to a catalogue by its OID according to ISO/IEC 8824-1:2015 using the dot-notation (example: "1.2.250.1").</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="catalogueElement" type="com:String" minOccurs="1" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>A reference to a specific element within the specified catalogue. The notation of this reference also depends on the specified catalogue.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="_catalogueInformationExtension" type="com:_ExtensionType" minOccurs="0" />
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="Component">
    <xs:annotation>
      <xs:documentation>Components of a device which have some special interest such as having status and faults of their own</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="fst:Device">
        <xs:sequence>
          <xs:element name="componentType" type="fst:_DeviceComponentEnum" minOccurs="1" maxOccurs="1">
            <xs:annotation>
              <xs:documentation>Type of device component</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="_componentExtension" type="com:_ExtensionType" minOccurs="0" />
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>
  <xs:complexType name="Device">
    <xs:annotation>
      <xs:documentation>Static information about a logical device that delivers a service. A device can announce itself, or the information can be enriched by operators.</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="typeOfDevice" type="fst:_DeviceTypeEnum" minOccurs="1" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>Information about the type of the device.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="lastUpdateOfDeviceInformation" type="com:DateTime" minOccurs="1" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>Time of the last update of the device information, i.e. the time of the information in this class was last updated.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="externalDeviceId" type="com:String" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>An external id or name for the device.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="lastDeviceCheck" type="com:DateTime" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>The time the device was last checked. Depending on local policies, this can be a physical check or just an online check.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="softwareVersion" type="com:String" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>Information on the current software version of the device.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="softwareVersionDate" type="com:DateTime" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>Information on the date of the current software version of the device.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="additionalDeviceInformation" type="com:MultilingualString" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>Any additional device information.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ipAddress" type="comx:IpAddress" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>IP address associated with the device</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="portNumber" type="comx:PortNumber" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>Primary TCP or UDP port number associated with device</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="accountableAuthority" type="com:InternationalIdentifier" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Information about the authority accountable for this device. Use this attribute only in case it differs from the accountable authority of the table of devices or the information manager declared within the PayloadPublication.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="pointLocation" type="loc:PointLocation" />
      <xs:element name="physicalDeviceDetails" type="fst:PhysicalDeviceDetails" minOccurs="0" />
      <xs:element name="component" type="fst:Component" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>Components of this device which have some special interest such as having status and faults of their own</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="dependsOn" type="fst:DeviceReference" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>Other devices (other than components of this device) whose services this device depends on in order to deliver its service</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="_deviceExtension" type="com:_ExtensionType" minOccurs="0" />
    </xs:sequence>
    <xs:attribute name="id" type="xs:string" use="required" />
    <xs:attribute name="version" type="xs:string" use="required" />
  </xs:complexType>
  <xs:simpleType name="DeviceComponentEnum">
    <xs:annotation>
      <xs:documentation>Type of component of a device</xs:documentation>
    </xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="ambientLightMonitor">
        <xs:annotation>
          <xs:documentation>Ambient light monitor</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="cabinet">
        <xs:annotation>
          <xs:documentation>Cabinet providing housing for equipment</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="communicationsEquipment">
        <xs:annotation>
          <xs:documentation>Communuications equipment</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="controller">
        <xs:annotation>
          <xs:documentation>A device controller</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="display">
        <xs:annotation>
          <xs:documentation>A display of a device</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="fan">
        <xs:annotation>
          <xs:documentation>Fan for device cooling</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="generalPurposeIoPort">
        <xs:annotation>
          <xs:documentation>General-purpose I/O port</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="heater">
        <xs:annotation>
          <xs:documentation>Heater to maintain operational temperature for a device</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="powerSupply">
        <xs:annotation>
          <xs:documentation>Power supply for a device</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="processor">
        <xs:annotation>
          <xs:documentation>Processor component of a device</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="sensor">
        <xs:annotation>
          <xs:documentation>Sensor component of a device</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="other">
        <xs:annotation>
          <xs:documentation>Other type of device component</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="_extended" />
    </xs:restriction>
  </xs:simpleType>
  <xs:complexType name="DeviceFault">
    <xs:annotation>
      <xs:documentation>Information about a fault relating to a specific device</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="com:Fault">
        <xs:sequence>
          <xs:element name="faultType" type="fst:_FaultTypeEnum" minOccurs="1" maxOccurs="1">
            <xs:annotation>
              <xs:documentation>The type of fault.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="faultInstructions" type="com:MultilingualString" minOccurs="0" maxOccurs="1">
            <xs:annotation>
              <xs:documentation>Instructions to rectify this fault.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="faultImpactOnData" type="fst:_FaultImpactOnDataEnum" minOccurs="0" maxOccurs="unbounded">
            <xs:annotation>
              <xs:documentation>The impact on data of this fault.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="faultComponent" type="com:String" minOccurs="0" maxOccurs="1">
            <xs:annotation>
              <xs:documentation>Identity of the component (if any), in which the fault occurred.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="faultComponentType" type="fst:_DeviceComponentEnum" minOccurs="0" maxOccurs="1">
            <xs:annotation>
              <xs:documentation>The fault comes from a component of this device, of the identified component type.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="faultObjectInformation" type="fst:CatalogueInformation" minOccurs="0">
            <xs:annotation>
              <xs:documentation>A reference to specific additional information on the fault by referencing a predefined element out of some catalogue.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="_deviceFaultExtension" type="com:_ExtensionType" minOccurs="0" />
        </xs:sequence>
        <xs:attribute name="id" type="xs:string" use="required" />
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>
  <xs:simpleType name="DeviceHealthEnum">
    <xs:annotation>
      <xs:documentation>This enumeration provides information on the health status of a device, in terms of its ability to provide its functional service.</xs:documentation>
    </xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="ok">
        <xs:annotation>
          <xs:documentation>The device is working properly according to its specified requirements.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="notOk">
        <xs:annotation>
          <xs:documentation>The device is not working properly according to its specified requirements. A reference to a fault may be provided.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="functionalityPartlyOk">
        <xs:annotation>
          <xs:documentation>Some specific functionality of the device is working properly according to its specified requirements, but some other is not.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="intermittentlyOk">
        <xs:annotation>
          <xs:documentation>The device is sometimes working properly according to its specified requirements, but on occasions is not. A reference to a fault may be provided.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="alarm">
        <xs:annotation>
          <xs:documentation>There is an indication of a fault danger or some other undesirable effects. An example might be an environmental alarm, for instance the device-temperature being above a certain threshold.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="notResponding">
        <xs:annotation>
          <xs:documentation>The device does not respond on calling. Nevertheless, it can be possible that the device still sends data. Normally this information is gathered from a system trigger or log trace, which is acknowledged and recorded by an operator.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="offline">
        <xs:annotation>
          <xs:documentation>The device is not connected or cannot be contacted. A reference to a fault may be provided. Usually, this information is  generated by an operator.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="unknown">
        <xs:annotation>
          <xs:documentation>The status of the device is unknown.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="_extended" />
    </xs:restriction>
  </xs:simpleType>
  <xs:complexType name="DevicePower">
    <xs:annotation>
      <xs:documentation>Power source for a device</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="health" type="fst:_DeviceHealthEnum" minOccurs="1" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>Health of the power supply</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="sourceType" type="fst:_PowerSourceEnum" minOccurs="1" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>Type of power supply</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="_devicePowerExtension" type="com:_ExtensionType" minOccurs="0" />
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="DevicePublication">
    <xs:annotation>
      <xs:documentation>This publication provides static information about devices, including its point-location. It can be used in case no specific publication for the type of device is available or suitable. Fault- and StatusPublication can reference to the specified devices.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="com:PayloadPublication">
        <xs:sequence>
          <xs:element name="headerInformation" type="com:HeaderInformation" />
          <xs:element name="device" type="fst:Device" minOccurs="0" maxOccurs="unbounded" />
          <xs:element name="deviceTable" type="fst:DeviceTable" minOccurs="0" maxOccurs="unbounded" />
          <xs:element name="_devicePublicationExtension" type="com:_ExtensionType" minOccurs="0" />
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>
  <xs:complexType name="DeviceReference" abstract="true">
    <xs:annotation>
      <xs:documentation>A reference to a single device, either by using the VMS-structure or the MeasurementSitePublication structure or the DevicePublication structure.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="com:GlobalReference">
        <xs:sequence>
          <xs:element name="_deviceReferenceExtension" type="com:_ExtensionType" minOccurs="0" />
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>
  <xs:complexType name="DeviceTable">
    <xs:annotation>
      <xs:documentation>A table of devices grouped by any logical criteria, e.g. all traffic lights within a certain administrative area.</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="deviceTableName" type="com:String" minOccurs="0" maxOccurs="1">
        <xs:annotation>
          <xs:documentation>The name of the table of devices.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="accountableAuthority" type="com:InternationalIdentifier" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Information about the authority accountable for this table of devices. Use this attribute only in the case where it differs from the information manager declared within the PayloadPublication.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="device" type="fst:Device" maxOccurs="unbounded" />
      <xs:element name="_deviceTableExtension" type="com:_ExtensionType" minOccurs="0" />
    </xs:sequence>
    <xs:attribute name="id" type="xs:string" use="required" />
    <xs:attribute name="version" type="xs:string" use="required" />
  </xs:complexType>
  <xs:complexType name="DeviceTableReference" abstract="true">
    <xs:annotation>
      <xs:documentation>A reference to a device table, either by using the VMS- or the MeasurementSitePublication structure or the DevicePublication structure.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="com:GlobalReference">
        <xs:sequence>
          <xs:element name="_deviceTableReferenceExtension" type="com:_ExtensionType" minOccurs="0" />
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>
