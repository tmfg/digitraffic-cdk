      <xs:enumeration value="configurationError">
        <xs:annotation>
          <xs:documentation>An error in the configuration or supply data of the device.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="disconnected">
        <xs:annotation>
          <xs:documentation>The device or component has no connection</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="electronicsFault">
        <xs:annotation>
          <xs:documentation>A fault in the electronics part of the device.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="generalSystemError">
        <xs:annotation>
          <xs:documentation>A general system error.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="hardwareFault">
        <xs:annotation>
          <xs:documentation>A hardware-related fault.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="controlFault">
        <xs:annotation>
          <xs:documentation>An invalid state was called by the control unit.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="intermittentlyWorking">
        <xs:annotation>
          <xs:documentation>The device or component cannot always perform its tasks as required.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="mechanicalFault">
        <xs:annotation>
          <xs:documentation>A fault of a mechanical part of the device.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="notWorking">
        <xs:annotation>
          <xs:documentation>The device or component cannot perform its tasks.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="operatingSystemFault">
        <xs:annotation>
          <xs:documentation>A fault in the operating system of the device.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="powerFailure">
        <xs:annotation>
          <xs:documentation>There is no power supply for the device or component.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="securityFault">
        <xs:annotation>
          <xs:documentation>A fault that causes a security issue or harms security related services.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="softwareFault">
