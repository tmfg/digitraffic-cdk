        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="unspecifiedFault">
        <xs:annotation>
          <xs:documentation>The fault cannot be specified.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="unknownFault">
        <xs:annotation>
          <xs:documentation>The fault is unknown.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="otherFault">
        <xs:annotation>
          <xs:documentation>The fault is not included in this enumeration.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
