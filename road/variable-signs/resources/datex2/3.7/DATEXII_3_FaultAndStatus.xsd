          <xs:documentation>A software-related fault.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="synchronizationFault">
        <xs:annotation>
          <xs:documentation>Fault in the process of synchronisation with the device</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="timeOrClockFault">
