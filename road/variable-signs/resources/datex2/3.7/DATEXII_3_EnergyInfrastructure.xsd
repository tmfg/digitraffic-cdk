        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="apps">
        <xs:annotation>
          <xs:documentation>Apps</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="calypso">
        <xs:annotation>
          <xs:documentation>RFID Calypso</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="cashPayment">
        <xs:annotation>
          <xs:documentation>No specific authentication by using cash</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="creditCard">
        <xs:annotation>
          <xs:documentation>Credit card</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="debitCard">
        <xs:annotation>
          <xs:documentation>Debit card</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="mifareClassic">
        <xs:annotation>
          <xs:documentation>RFID Card / Phone NFC - Mifare Classic</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="mifareDesfire">
        <xs:annotation>
          <xs:documentation>RFID Card / Phone NFC - Mifare Desfire</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="nfc">
        <xs:annotation>
          <xs:documentation>Nearfield communication</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="overTheAir">
        <xs:annotation>
          <xs:documentation>Over the air according to ISO 15118</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="phoneDialog">
        <xs:annotation>
          <xs:documentation>phone (dialog with platform)</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="phoneSMS">
        <xs:annotation>
          <xs:documentation>Phone (SMS)</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="pinpad">
        <xs:annotation>
          <xs:documentation>PINPAD</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="plc">
        <xs:annotation>
          <xs:documentation>PLC according to ISO 15118</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="prepaidCard">
        <xs:annotation>
          <xs:documentation>Pre-Paid card</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="rfid">
        <xs:annotation>
          <xs:documentation>RFID</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="website">
        <xs:annotation>
          <xs:documentation>Using a website</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="unlimitedAccess">
        <xs:annotation>
          <xs:documentation>No authentication/identification required.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="noAccess">
        <xs:annotation>
          <xs:documentation>No access granted</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
