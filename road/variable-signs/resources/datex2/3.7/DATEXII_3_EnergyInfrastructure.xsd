        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="blocked">
        <xs:annotation>
          <xs:documentation>The refill point is not accessible because of a physical barrier, e.g. a car.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="charging">
