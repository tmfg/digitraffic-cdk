{
  "name": "data-upload",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc && npm run build:bundle",
    "build:bundle": "npm run compile-lambdas",
    "cdk": "cdk",
    "cdk-deploy-road-prod": "../../scripts/cdk-diff-and-deploy.sh road-prod deploy",
    "cdk-deploy-road-test": "../../scripts/cdk-diff-and-deploy.sh road-test deploy",
    "cdk-diff-road-prod": "../../scripts/cdk-diff-and-deploy.sh road-prod diff",
    "cdk-diff-road-test": "../../scripts/cdk-diff-and-deploy.sh road-test diff",
    "ci:test": "vitest run --reporter=junit --outputFile=test-results.xml",
    "clean": "rimraf dist cdk.out",
    "clean:force": "rimraf dist cdk.out node_modules",
    "compile-lambdas": "node lib/esbuild.js",
    "compile-lambdas-old": "esbuild src/lambda/**/*.ts --log-level=warning --minify --bundle --platform=node --outdir=dist/lambda --out-extension:.js=.mjs --format=esm --target=node22 --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\"",
    "synth-sam": "cdk synth --no-staging > template.yaml",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@digitraffic/common": "2026.3.17-2",
    "@rgrove/parse-xml": "4.2.0",
    "aws-cdk-lib": "2.248.0",
    "constructs": "10.6.0",
    "mqtt": "5.15.1",
    "pg-native": "3.7.0",
    "pg-promise": "12.6.2",
    "uuid": "13.0.0",
    "xml2js": "0.6.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@aws-sdk/client-api-gateway": "3.1028.0",
    "@aws-sdk/client-sqs": "3.1028.0",
    "@digitraffic-cdk/cdk-rig": "workspace:*",
    "@digitraffic-cdk/esbuild": "workspace:*",
    "@digitraffic-cdk/testing": "workspace:*",
    "@digitraffic-cdk/toolchain": "workspace:*",
    "@rushstack/heft": "1.2.11",
    "@types/aws-lambda": "8.10.161",
    "@types/node": "24.12.2",
    "@types/xml2js": "0.4.14",
    "@vitest/coverage-v8": "4.1.4",
    "aws-cdk": "2.1118.0",
    "esbuild": "0.28.0",
    "parallelshell": "3.0.2",
    "spex": "4.1.0",
    "typescript": "5.9.3",
    "vitest": "4.1.4"
  }
}
