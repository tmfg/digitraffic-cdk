{
  "name": "counting-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "heft build --clean && npm run build:bundle",
    "build:bundle": "npm run compile-lambdas && npm run compile-canaries",
    "cdk": "cdk",
    "cdk-deploy-road-prod": "rushx build && ../../scripts/cdk-diff-and-deploy.sh road-prod deploy CountingSiteProd",
    "cdk-deploy-road-test": "rushx build && ../../scripts/cdk-diff-and-deploy.sh road-test deploy CountingSiteTest",
    "cdk-diff-road-prod": "rushx build && ../../scripts/cdk-diff-and-deploy.sh road-prod diff CountingSiteProd",
    "cdk-diff-road-test": "rushx build && ../../scripts/cdk-diff-and-deploy.sh road-test diff CountingSiteTest",
    "ci:test": "vitest run --reporter=junit --outputFile=test-results.xml",
    "clean": "rimraf dist cdk.out",
    "clean:force": "rimraf dist cdk.out node_modules",
    "compile-canaries": "esbuild src/canaries/*.ts --log-level=warning --bundle --platform=node --outdir=dist/nodejs/node_modules --external:Synthetics --target=node22",
    "compile-lambdas": "node lib/esbuild.js",
    "synth-sam": "cdk synth --no-staging > template.yaml",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@date-fns/tz": "1.5.0",
    "@digitraffic/common": "2026.5.27-1",
    "@std/csv": "npm:@jsr/std__csv@1.0.6",
    "aws-cdk-lib": "2.260.0",
    "constructs": "10.6.0",
    "date-fns": "4.4.0",
    "geojson": "0.5.0",
    "geojson-validation": "1.0.2",
    "ky": "2.0.2",
    "kysely": "0.29.2",
    "pg-native": "3.8.0",
    "pg-promise": "12.6.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@digitraffic-cdk/cdk-rig": "workspace:*",
    "@digitraffic-cdk/esbuild": "workspace:*",
    "@digitraffic-cdk/testing": "workspace:*",
    "@digitraffic-cdk/toolchain": "workspace:*",
    "@rushstack/heft": "1.2.19",
    "@types/aws-lambda": "8.10.162",
    "@types/geojson": "7946.0.16",
    "@types/node": "24.12.2",
    "@vitest/coverage-v8": "4.1.9",
    "aws-cdk": "2.1128.0",
    "esbuild": "0.28.1",
    "parallelshell": "3.0.2",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "vitest": "4.1.9"
  }
}
