{
  "name": "cloudfront",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "heft build --clean && npm run build:bundle",
    "build:bundle": "npm run compile-lambdas",
    "build:tsc": "heft build --clean",
    "build:watch": "heft build-watch --clean",
    "cdk": "cdk",
    "cdk-deploy-afir-prod": "../../scripts/cdk-diff-and-deploy.sh afir-prod deploy CloudfrontAfirProd",
    "cdk-deploy-afir-test": "../../scripts/cdk-diff-and-deploy.sh afir-test deploy CloudfrontAfirTest",
    "cdk-deploy-marine-prod": "../../scripts/cdk-diff-and-deploy.sh marine-prod deploy CloudfrontMarineProd",
    "cdk-deploy-marine-test": "../../scripts/cdk-diff-and-deploy.sh marine-test deploy CloudfrontMarineTest",
    "cdk-deploy-road-prod": "../../scripts/cdk-diff-and-deploy.sh road-prod deploy CloudfrontRoadProd",
    "cdk-deploy-road-test": "../../scripts/cdk-diff-and-deploy.sh road-test deploy CloudfrontRoadTest",
    "cdk-deploy-status-test": "../../scripts/cdk-diff-and-deploy.sh status-test diff CloudfrontStatusTest",
    "cdk-diff-afir-prod": "../../scripts/cdk-diff-and-deploy.sh afir-prod diff CloudfrontAfirProd",
    "cdk-diff-afir-test": "../../scripts/cdk-diff-and-deploy.sh afir-test diff CloudfrontAfirTest",
    "cdk-diff-marine-prod": "../../scripts/cdk-diff-and-deploy.sh marine-prod diff CloudfrontMarineProd",
    "cdk-diff-marine-test": "../../scripts/cdk-diff-and-deploy.sh marine-test diff CloudfrontMarineTest",
    "cdk-diff-road-prod": "../../scripts/cdk-diff-and-deploy.sh road-prod diff CloudfrontRoadProd",
    "cdk-diff-road-test": "../../scripts/cdk-diff-and-deploy.sh road-test diff CloudfrontRoadTest",
    "cdk-diff-status-test": "../../scripts/cdk-diff-and-deploy.sh status-test deploy CloudfrontStatusTest",
    "ci:test": "vitest run --reporter=junit --outputFile=test-results.xml",
    "compile-lambdas": "rollup -c",
    "synth-sam": "cdk synth --no-staging > template.yaml",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@digitraffic/common": "2026.3.17-2",
    "aws-cdk-lib": "2.241.0",
    "constructs": "10.5.1"
  },
  "devDependencies": {
    "@aws-sdk/client-api-gateway": "3.1004.0",
    "@aws-sdk/client-ssm": "3.1004.0",
    "@digitraffic-cdk/cdk-rig": "workspace:*",
    "@digitraffic-cdk/esbuild": "workspace:*",
    "@digitraffic-cdk/testing": "workspace:*",
    "@digitraffic-cdk/toolchain": "workspace:*",
    "@rollup/plugin-commonjs": "29.0.2",
    "@rollup/plugin-json": "6.1.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-terser": "1.0.0",
    "@rollup/plugin-typescript": "12.3.0",
    "@rushstack/heft": "1.2.6",
    "@types/aws-lambda": "8.10.161",
    "@types/node": "25.3.5",
    "@vitest/coverage-v8": "4.0.18",
    "aws-cdk": "2.1111.0",
    "esbuild": "0.27.3",
    "globby": "16.1.1",
    "parallelshell": "3.0.2",
    "rollup": "4.59.0",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
