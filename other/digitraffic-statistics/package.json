{
  "name": "digitraffic-statistics",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "heft build --clean",
    "build:bundle": "npm run compile-lambdas",
    "build:tsc": "heft build --clean",
    "build:watch": "heft build-watch --clean",
    "cdk": "cdk",
    "ci:test": "vitest run --reporter=junit --outputFile=test-results.xml",
    "compile-lambdas": "node lib/esbuild.js",
    "compile-lambdas-old": "esbuild src/lambda/**/*.ts --log-level=warning --bundle --platform=node --outdir=dist/lambda --target=node22,es2022",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@digitraffic/common": "2026.3.17-2",
    "aws-cdk-lib": "2.241.0",
    "constructs": "10.5.1"
  },
  "devDependencies": {
    "@digitraffic-cdk/cdk-rig": "workspace:*",
    "@digitraffic-cdk/esbuild": "workspace:*",
    "@digitraffic-cdk/testing": "workspace:*",
    "@digitraffic-cdk/toolchain": "workspace:*",
    "@rushstack/heft": "1.2.6",
    "@types/aws-lambda": "8.10.160",
    "@types/node": "25.3.3",
    "@vitest/coverage-v8": "4.0.18",
    "aws-cdk": "2.1109.0",
    "cdk-ecr-deployment": "4.0.6",
    "esbuild": "0.27.2",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "externals": []
}
