{
  "name": "test-api-stack",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "heft build --clean && npm run build:bundle",
    "build:bundle": "npm run compile-lambdas",
    "build:tsc": "heft build --clean",
    "build:watch": "heft build-watch --clean",
    "cdk": "cdk",
    "cdk-deploy-marine-prod": "../../scripts/cdk-diff-and-deploy.sh marine-prod deploy",
    "cdk-deploy-marine-test": "../../scripts/cdk-diff-and-deploy.sh marine-test deploy",
    "cdk-diff-marine-prod": "../../scripts/cdk-diff-and-deploy.sh marine-prod diff",
    "cdk-diff-marine-test": "../../scripts/cdk-diff-and-deploy.sh marine-test diff",
    "ci:test": "vitest run --reporter=junit --outputFile=test-results.xml",
    "compile-lambdas": "node lib/esbuild.js",
    "compile-lambdas-old": "esbuild src/lambda/**/*.ts --log-level=warning --bundle --platform=node --outdir=dist/lambda --target=node22",
    "synth-sam": "cdk synth --no-staging > template.yaml",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@digitraffic/common": "2026.3.17-2",
    "aws-cdk-lib": "2.248.0",
    "constructs": "10.6.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@digitraffic-cdk/cdk-rig": "workspace:*",
    "@digitraffic-cdk/esbuild": "workspace:*",
    "@digitraffic-cdk/testing": "workspace:*",
    "@digitraffic-cdk/toolchain": "workspace:*",
    "@rushstack/heft": "1.2.11",
    "@types/aws-lambda": "8.10.161",
    "@types/node": "24.12.2",
    "@vitest/coverage-v8": "4.1.4",
    "aws-cdk": "2.1118.0",
    "esbuild": "0.28.0",
    "parallelshell": "3.0.2",
    "typescript": "5.9.3",
    "vitest": "4.1.4"
  }
}
