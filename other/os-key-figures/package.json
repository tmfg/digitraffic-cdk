{
  "name": "os-key-figures",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "heft build --clean && npm run compile-lambdas",
    "build:watch": "heft build-watch --clean",
    "cdk": "cdk",
    "ci:prepare": "npm run test:integration:setup",
    "ci:teardown": "npm run test:integration:teardown",
    "ci:test": "vitest run --reporter=junit --outputFile=test-results.xml",
    "compile-lambdas": "node lib/esbuild.js",
    "compile-lambdas-old": "esbuild src/lambda/*.ts --log-level=warning --bundle --platform=node --outdir=dist/lambda --target=node24",
    "synth-sam": "cdk synth --no-staging > template.yaml",
    "test": "vitest run",
    "test:integration": "vitest run -t '.*integration.*'",
    "test:integration:setup": "docker compose -f src/__test__/integration/docker-compose.yml up -d && echo 'Waiting for containers...' && sleep 10",
    "test:integration:teardown": "docker compose -f src/__test__/integration/docker-compose.yml down -v",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-crypto/sha256-browser": "5.2.0",
    "@aws-sdk/client-s3": "3.1028.0",
    "@aws-sdk/client-sts": "3.1028.0",
    "@digitraffic/common": "2026.4.17-2",
    "@smithy/node-http-handler": "4.5.2",
    "@smithy/protocol-http": "5.3.13",
    "@smithy/signature-v4": "5.3.13",
    "aws-cdk-lib": "2.248.0",
    "constructs": "10.6.0",
    "ky": "1.14.3",
    "mysql": "2.18.1",
    "source-map-support": "0.5.21"
  },
  "devDependencies": {
    "@aws-sdk/types": "3.973.7",
    "@digitraffic-cdk/cdk-rig": "workspace:*",
    "@digitraffic-cdk/esbuild": "workspace:*",
    "@digitraffic-cdk/testing": "workspace:*",
    "@digitraffic-cdk/toolchain": "workspace:*",
    "@rushstack/heft": "1.2.11",
    "@types/aws-lambda": "8.10.161",
    "@types/mysql": "2.15.27",
    "@types/node": "24.12.2",
    "@types/sinon": "21.0.1",
    "@vitest/coverage-v8": "4.1.4",
    "aws-cdk": "2.1118.0",
    "dotenv": "17.4.1",
    "esbuild": "0.28.0",
    "nock": "15.0.0",
    "node-mocks-http": "1.17.2",
    "parallelshell": "3.0.2",
    "sinon": "21.1.0",
    "typescript": "5.9.3",
    "vitest": "4.1.4",
    "zod": "4.3.6"
  }
}
