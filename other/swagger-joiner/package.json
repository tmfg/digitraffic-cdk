{
  "name": "swagger-joiner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "heft build --clean && npm run build:bundle",
    "build:bundle": "npm run compile-lambdas && npm run compile-canaries",
    "build:tsc": "heft build --clean",
    "build:watch": "heft build-watch --clean",
    "cdk": "cdk",
    "cdk-deploy-afir-prod": "rushx build && ../../scripts/cdk-diff-and-deploy.sh afir-prod deploy SwaggerJoinerAfirProd",
    "cdk-deploy-afir-test": "rushx build && ../../scripts/cdk-diff-and-deploy.sh afir-test deploy",
    "cdk-deploy-marine-prod": "rushx build && ../../scripts/cdk-diff-and-deploy.sh marine-prod deploy",
    "cdk-deploy-marine-test": "rushx build && ../../scripts/cdk-diff-and-deploy.sh marine-test deploy",
    "cdk-deploy-rail-prod": "rushx build && ../../scripts/cdk-diff-and-deploy.sh rail-prod deploy SwaggerJoinerRailProd",
    "cdk-deploy-rail-test": "rushx build && ../../scripts/cdk-diff-and-deploy.sh rail-test deploy SwaggerJoinerRailBeta",
    "cdk-deploy-road-prod": "rushx build && ../../scripts/cdk-diff-and-deploy.sh road-prod deploy",
    "cdk-deploy-road-test": "rushx build && ../../scripts/cdk-diff-and-deploy.sh road-test deploy",
    "cdk-diff-afir-prod": "rushx build && ../../scripts/cdk-diff-and-deploy.sh afir-prod diff SwaggerJoinerAfirProd",
    "cdk-diff-afir-test": "rushx build && ../../scripts/cdk-diff-and-deploy.sh afir-test diff SwaggerJoinerAfirTest",
    "cdk-diff-marine-prod": "rushx build && ../../scripts/cdk-diff-and-deploy.sh marine-prod diff",
    "cdk-diff-marine-test": "rushx build && ../../scripts/cdk-diff-and-deploy.sh marine-test diff",
    "cdk-diff-rail-prod": "rushx build && ../../scripts/cdk-diff-and-deploy.sh rail-prod diff SwaggerJoinerRailProd",
    "cdk-diff-rail-test": "rushx build && ../../scripts/cdk-diff-and-deploy.sh rail-test diff SwaggerJoinerRailBeta",
    "cdk-diff-road-prod": "rushx build && ../../scripts/cdk-diff-and-deploy.sh road-prod diff",
    "cdk-diff-road-test": "rushx build && ../../scripts/cdk-diff-and-deploy.sh road-test diff",
    "ci:test": "vitest run --reporter=junit --outputFile=test-results.xml",
    "clean:force": "rimraf dist cdk.out node_modules",
    "compile-canaries": "echo 'No canaries'",
    "compile-canaries_": "esbuild src/canaries/*.ts --log-level=warning --bundle --format=esm --platform=node --outdir=dist/nodejs/node_modules --external:Synthetics --target=node22,es2020",
    "compile-lambdas": "node lib/esbuild.js",
    "compile-lambdas-old": "esbuild src/lambda/**/*.ts --log-level=warning --bundle --format=esm --platform=node --outdir=dist/lambda --target=node22,es2022  --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\" --out-extension:.js=.mjs",
    "synth-sam": "cdk synth --no-staging > template.yaml",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-api-gateway": "3.1073.0",
    "@aws-sdk/client-s3": "3.1073.0",
    "@digitraffic/common": "2026.5.27-1",
    "aws-cdk-lib": "2.260.0",
    "constructs": "10.6.0",
    "es-toolkit": "1.47.1",
    "ky": "2.0.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@digitraffic-cdk/cdk-rig": "workspace:*",
    "@digitraffic-cdk/esbuild": "workspace:*",
    "@digitraffic-cdk/testing": "workspace:*",
    "@digitraffic-cdk/toolchain": "workspace:*",
    "@rushstack/heft": "1.2.19",
    "@types/aws-lambda": "8.10.162",
    "@types/node": "24.12.2",
    "@vitest/coverage-v8": "4.1.9",
    "aws-cdk": "2.1128.0",
    "esbuild": "0.28.1",
    "typescript": "5.9.3",
    "vitest": "4.1.9"
  }
}
