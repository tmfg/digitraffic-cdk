{
  "name": "aviation-data",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "heft build --clean",
    "cdk": "cdk",
    "ci:test": "vitest run --reporter=junit --outputFile=test-results.xml",
    "clean": "rimraf dist cdk.out",
    "clean:force": "rimraf dist cdk.out node_modules",
    "synth-sam": "cdk synth --no-staging > template.yaml",
    "test": "vitest run",
    "test:watch": "vitest",
    "watch": "tsc -w"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.995.0",
    "@aws-sdk/lib-storage": "3.995.0",
    "@digitraffic/common": "2026.3.3-1",
    "aws-cdk-lib": "2.236.0",
    "constructs": "10.4.5"
  },
  "devDependencies": {
    "@digitraffic-cdk/cdk-rig": "workspace:*",
    "@digitraffic-cdk/esbuild": "workspace:*",
    "@digitraffic-cdk/testing": "workspace:*",
    "@digitraffic-cdk/toolchain": "workspace:*",
    "@rushstack/heft": "1.1.10",
    "@types/aws-lambda": "8.10.160",
    "@types/node": "24.10.13",
    "@vitest/coverage-v8": "4.0.18",
    "esbuild": "0.27.2",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "externals": []
}
