{
  "name": "rami",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "heft build --clean && npm run build:bundle",
    "build:bundle": "npm run compile-lambdas && npm run compile-canaries",
    "build:watch": "heft build-watch --clean",
    "cdk": "cdk",
    "ci:test": "vitest run --reporter=junit --outputFile=test-results.xml",
    "clean": "rimraf dist cdk.out",
    "clean:force": "rimraf dist cdk.out node_modules",
    "compile-canaries": "esbuild src/canaries/*.ts --log-level=warning --bundle --target=node22 --platform=node --outdir=dist/nodejs/node_modules --external:aws-sdk --external:Synthetics",
    "compile-lambdas": "node lib/esbuild.js",
    "synth-sam": "cdk synth --no-staging > template.yaml",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1028.0",
    "@aws-sdk/client-secrets-manager": "3.1028.0",
    "@aws-sdk/client-sqs": "3.1028.0",
    "@date-fns/tz": "1.4.1",
    "@digitraffic/common": "2026.3.17-2",
    "@middy/core": "7.2.1",
    "@middy/sqs-partial-batch-failure": "7.2.1",
    "ajv": "8.18.0",
    "ajv-formats": "3.0.1",
    "aws-cdk-lib": "2.248.0",
    "constructs": "10.6.0",
    "date-fns": "4.1.0",
    "mysql2": "3.21.1",
    "source-map-support": "0.5.21",
    "spex": "4.1.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@digitraffic-cdk/cdk-rig": "workspace:*",
    "@digitraffic-cdk/esbuild": "workspace:*",
    "@digitraffic-cdk/testing": "workspace:*",
    "@digitraffic-cdk/toolchain": "workspace:*",
    "@rushstack/heft": "1.2.11",
    "@types/aws-lambda": "8.10.161",
    "@types/lodash-es": "4.17.12",
    "@types/node": "24.12.2",
    "@vitest/coverage-v8": "4.1.4",
    "aws-cdk": "2.1118.0",
    "esbuild": "0.28.0",
    "lodash-es": "4.18.1",
    "parallelshell": "3.0.2",
    "typescript": "5.9.3",
    "vitest": "4.1.4"
  }
}
