{
  "name": "data-dump",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bash build-layer.sh && heft build --clean",
    "build:layer": "bash build-layer.sh",
    "cdk": "cdk",
    "ci:prepare": "poetry install",
    "ci:test": "vitest run --reporter=junit --outputFile=test-results.xml && poetry run python run_tests.py",
    "clean": "rimraf dist cdk.out",
    "clean:force": "rimraf dist cdk.out node_modules",
    "test": "vitest run",
    "test:python": "poetry run python run_tests.py",
    "watch": "tsc -w"
  },
  "dependencies": {
    "@digitraffic/common": "2026.4.17-3",
    "aws-cdk-lib": "2.248.0",
    "constructs": "10.6.0"
  },
  "devDependencies": {
    "@digitraffic-cdk/cdk-rig": "workspace:*",
    "@digitraffic-cdk/esbuild": "workspace:*",
    "@digitraffic-cdk/testing": "workspace:*",
    "@digitraffic-cdk/toolchain": "workspace:*",
    "@rushstack/heft": "1.2.11",
    "@rushstack/heft-jest-plugin": "1.2.6",
    "@types/aws-lambda": "8.10.161",
    "@types/heft-jest": "1.0.6",
    "@types/jest": "30.0.0",
    "@types/node": "24.12.2",
    "@vitest/coverage-v8": "4.1.4",
    "aws-cdk": "2.1118.0",
    "esbuild": "0.28.0",
    "parallelshell": "3.0.2",
    "typescript": "5.9.3",
    "vitest": "4.1.4"
  }
}
