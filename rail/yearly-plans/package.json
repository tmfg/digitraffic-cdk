{
  "name": "yearly-plans",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "heft build --clean && npm run build:bundle",
    "build:bundle": "npm run compile-lambdas",
    "build:tsc": "heft build --clean",
    "build:watch": "heft build-watch --clean",
    "cdk": "cdk",
    "ci:test": "vitest run --reporter=junit --outputFile=test-results.xml",
    "compile-lambdas": "node lib/esbuild.js",
    "compile-lambdas-old": "esbuild src/lambda/**/*.ts --log-level=warning --bundle --platform=node --outdir=dist/lambda/update-plans --target=node22,es2022",
    "convert-schema": "node src/scripts/schema-fix.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1004.0",
    "@digitraffic/common": "2026.3.17-2",
    "ajv": "8.18.0",
    "ajv-formats": "3.0.1",
    "archiver": "7.0.1",
    "aws-cdk-lib": "2.241.0",
    "constructs": "10.5.1",
    "ky": "1.14.3"
  },
  "devDependencies": {
    "@digitraffic-cdk/cdk-rig": "workspace:*",
    "@digitraffic-cdk/esbuild": "workspace:*",
    "@digitraffic-cdk/testing": "workspace:*",
    "@digitraffic-cdk/toolchain": "workspace:*",
    "@rushstack/heft": "1.2.6",
    "@types/archiver": "7.0.0",
    "@types/node": "25.3.5",
    "@vitest/coverage-v8": "4.0.18",
    "aws-cdk": "3.0.0",
    "esbuild": "0.27.3",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
