{
  "name": "portactivity",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "heft build --clean && npm run build:bundle",
    "build:bundle": "npm run compile-lambdas && npm run compile-canaries",
    "build:tsc": "heft build --clean",
    "build:watch": "heft build-watch --clean",
    "cdk": "cdk",
    "ci:prepare": "cd database && ./update-db.sh ci migrate host",
    "ci:test": "vitest run --reporter=junit --outputFile=test-results.xml",
    "clean": "rimraf dist cdk.out",
    "clean:force": "rimraf dist cdk.out node_modules",
    "compile-canaries": "esbuild src/canaries/*.ts --log-level=warning --bundle --platform=node --outdir=dist/nodejs/node_modules --external:aws-sdk --external:Synthetics --target=node22",
    "compile-lambdas": "node lib/esbuild.js",
    "compile-lambdas-old": "esbuild src/lambda/**/*.ts --log-level=warning --bundle --platform=node --outdir=dist/lambda --target=node24",
    "synth-sam": "cdk synth --no-staging > template.yaml",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.995.0",
    "@aws-sdk/client-sns": "3.995.0",
    "@aws-sdk/client-sqs": "3.995.0",
    "@aws-sdk/client-ssm": "3.995.0",
    "@date-fns/tz": "1.4.1",
    "@digitraffic/common": "2026.3.5-1",
    "@middy/core": "7.0.2",
    "@middy/sqs-partial-batch-failure": "7.0.2",
    "amqplib": "0.10.9",
    "aws-cdk-lib": "2.241.0",
    "constructs": "10.5.1",
    "date-fns": "4.1.0",
    "ky": "1.14.3",
    "lodash": "4.17.23",
    "pg-native": "3.5.2",
    "pg-promise": "12.3.0",
    "spex": "4.1.0",
    "uuid": "13.0.0",
    "ws": "8.19.0",
    "xml2js": "0.6.2"
  },
  "devDependencies": {
    "@digitraffic-cdk/cdk-rig": "workspace:*",
    "@digitraffic-cdk/esbuild": "workspace:*",
    "@digitraffic-cdk/testing": "workspace:*",
    "@digitraffic-cdk/toolchain": "workspace:*",
    "@rushstack/heft": "1.2.6",
    "@types/amqplib": "0.10.8",
    "@types/aws-lambda": "8.10.160",
    "@types/lodash": "4.17.23",
    "@types/node": "25.3.3",
    "@types/sinon": "21.0.0",
    "@types/ws": "8.18.1",
    "@types/xml2js": "0.4.14",
    "@vitest/coverage-v8": "4.0.18",
    "aws-cdk": "2.1109.0",
    "esbuild": "0.27.2",
    "parallelshell": "3.0.2",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
