{
  "name": "sea-state-estimate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "json2ts -i src/schemas/ -o src/generated/",
    "build": "npm run prebuild && heft build --clean && npm run compile-lambdas",
    "cdk": "cdk",
    "cdk-deploy-marine-prod": "rushx build && ../../scripts/cdk-diff-and-deploy.sh marine-prod deploy",
    "cdk-deploy-marine-test": "rushx build && ../../scripts/cdk-diff-and-deploy.sh marine-test deploy",
    "cdk-diff-marine-prod": "rushx build && ../../scripts/cdk-diff-and-deploy.sh marine-prod diff",
    "cdk-diff-marine-test": "rushx build && ../../scripts/cdk-diff-and-deploy.sh marine-test diff",
    "ci:test": "vitest run --reporter=junit --outputFile=test-results.xml",
    "compile-lambdas": "node lib/esbuild.js",
    "compile-lambdas-old": "esbuild src/lambda/**/*.ts --log-level=warning --bundle --platform=node --outdir=dist/lambda --target=node22",
    "synth-sam": "cdk synth --no-staging > template.yaml",
    "pretest": "json2ts -i src/schemas/ -o lib/generated/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@digitraffic/common": "2026.4.17-3",
    "aws-cdk-lib": "2.248.0",
    "constructs": "10.6.0",
    "pg-native": "3.7.0",
    "pg-promise": "12.6.2"
  },
  "devDependencies": {
    "@digitraffic-cdk/cdk-rig": "workspace:*",
    "@digitraffic-cdk/esbuild": "workspace:*",
    "@digitraffic-cdk/testing": "workspace:*",
    "@digitraffic-cdk/toolchain": "workspace:*",
    "@rushstack/heft": "1.2.11",
    "@types/aws-lambda": "8.10.161",
    "@types/node": "24.12.2",
    "@types/sinon": "21.0.1",
    "@types/xml2js": "0.4.14",
    "@vitest/coverage-v8": "4.1.4",
    "aws-cdk": "2.1118.0",
    "esbuild": "0.28.0",
    "json-schema-to-typescript": "15.0.4",
    "parallelshell": "3.0.2",
    "sinon": "21.1.0",
    "typescript": "5.9.3",
    "vitest": "4.1.4"
  }
}
