{
  "name": "shiplight",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "heft build --clean && npm run build:bundle",
    "build:bundle": "npm run compile-lambdas",
    "cdk": "cdk",
    "cdk-deploy-marine-test": "../../scripts/cdk-diff-and-deploy.sh marine-test deploy ShiplightTest",
    "cdk-diff-marine-test": "../../scripts/cdk-diff-and-deploy.sh marine-test diff ShiplightTest",
    "ci:test": "vitest run --reporter=junit --outputFile=test-results.xml",
    "clean": "rimraf dist cdk.out",
    "clean:force": "rimraf dist cdk.out node_modules",
    "compile-canaries": "esbuild src/canaries/*.ts --log-level=warning --bundle --platform=node --outdir=dist/nodejs/node_modules --external:Synthetics --target=node22",
    "compile-lambdas": "node lib/esbuild.js",
    "synth-sam": "cdk synth --no-staging > template.yaml",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@digitraffic/common": "2026.3.5-1",
    "aws-cdk-lib": "2.241.0",
    "constructs": "10.5.1",
    "ky": "1.14.3",
    "pg-native": "3.7.0",
    "pg-promise": "12.6.2",
    "source-map-support": "0.5.21",
    "spex": "4.1.0",
    "uuid": "13.0.0"
  },
  "devDependencies": {
    "@digitraffic-cdk/cdk-rig": "workspace:*",
    "@digitraffic-cdk/esbuild": "workspace:*",
    "@digitraffic-cdk/testing": "workspace:*",
    "@digitraffic-cdk/toolchain": "workspace:*",
    "@rushstack/heft": "1.2.6",
    "@types/aws-lambda": "8.10.161",
    "@types/node": "25.3.5",
    "@types/xml2js": "0.4.14",
    "@vitest/coverage-v8": "4.0.18",
    "aws-cdk": "3.0.0",
    "esbuild": "0.27.3",
    "parallelshell": "3.0.2",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
