{
  "name": "winter-navigation",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "heft build --clean && npm run build:bundle",
    "build:bundle": "npm run compile-lambdas",
    "build:tsc": "heft build --clean",
    "build:watch": "heft build-watch --clean",
    "cdk": "cdk",
    "ci:test": "vitest run --reporter=junit --outputFile=test-results.xml",
    "compile-canaries": "esbuild src/canaries/*.ts --log-level=warning --bundle --platform=node --outdir=dist/nodejs/node_modules --external:Synthetics --target=node22,es2020",
    "compile-lambdas": "node lib/esbuild.js",
    "compile-lambdas-old": "esbuild src/lambda/**/*.ts --log-level=warning --bundle --platform=node --outdir=dist/lambda --target=node22,es2022",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@digitraffic/common": "2026.4.20-2",
    "aws-cdk-lib": "2.248.0",
    "constructs": "10.6.0",
    "es-toolkit": "1.45.1",
    "ky": "1.14.3",
    "pg-native": "3.7.0",
    "pg-promise": "12.6.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@digitraffic-cdk/cdk-rig": "workspace:*",
    "@digitraffic-cdk/esbuild": "workspace:*",
    "@digitraffic-cdk/testing": "workspace:*",
    "@digitraffic-cdk/toolchain": "workspace:*",
    "@rushstack/heft": "1.2.11",
    "@types/geojson": "7946.0.16",
    "@types/node": "24.12.2",
    "@vitest/coverage-v8": "4.1.4",
    "aws-cdk": "2.1118.0",
    "date-fns": "4.1.0",
    "esbuild": "0.28.0",
    "typescript": "5.9.3",
    "vitest": "4.1.4"
  }
}
