{
  "name": "port-call",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:tsc && npm run build:bundle",
    "build:bundle": "npm run compile-lambdas && npm run compile-canaries",
    "build:tsc": "heft build --clean",
    "build:watch": "heft build-watch --clean",
    "cdk": "cdk",
    "cdk-deploy-marine-prod": "../../scripts/cdk-diff-and-deploy.sh marine-prod deploy PortCallProd",
    "cdk-deploy-marine-test": "../../scripts/cdk-diff-and-deploy.sh marine-test deploy PortCallTest",
    "cdk-diff-marine-prod": "../../scripts/cdk-diff-and-deploy.sh marine-prod diff PortCallProd",
    "cdk-diff-marine-test": "../../scripts/cdk-diff-and-deploy.sh marine-test diff PortCallTest",
    "ci:test": "vitest run --reporter=junit --outputFile=test-results.xml",
    "clean": "rimraf dist cdk.out",
    "clean:force": "rimraf dist cdk.out node_modules",
    "compile-canaries": "echo 'No canaries' #esbuild src/canaries/*.ts --log-level=warning --bundle --platform=node --outdir=dist/nodejs/node_modules --external:aws-sdk --external:Synthetics --target=node20",
    "compile-lambdas": "node lib/esbuild.js",
    "synth-sam": "cdk synth --no-staging > template.yaml",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@digitraffic/common": "2026.5.27-1",
    "aws-cdk-lib": "2.260.0",
    "constructs": "10.6.0",
    "date-fns": "4.4.0",
    "es-toolkit": "1.47.1",
    "pg-native": "3.8.0",
    "pg-promise": "12.6.2",
    "undici": "8.5.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@digitraffic-cdk/cdk-rig": "workspace:*",
    "@digitraffic-cdk/esbuild": "workspace:*",
    "@digitraffic-cdk/testing": "workspace:*",
    "@digitraffic-cdk/toolchain": "workspace:*",
    "@rushstack/heft": "1.2.19",
    "@types/aws-lambda": "8.10.162",
    "@types/node": "24.12.2",
    "@vitest/coverage-v8": "4.1.9",
    "aws-cdk": "2.1128.0",
    "esbuild": "0.28.1",
    "parallelshell": "3.0.2",
    "typescript": "5.9.3",
    "vitest": "4.1.9"
  }
}
