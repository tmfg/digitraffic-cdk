{
  "name": "marinecam",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "heft build --clean && npm run build:bundle",
    "build:bundle": "npm run compile-lambdas && npm run compile-canaries",
    "cdk": "cdk",
    "ci:prepare": "cd database && ./update-db.sh ci migrate host",
    "ci:test": "vitest run --reporter=junit --outputFile=test-results.xml",
    "clean": "rimraf dist cdk.out",
    "clean:force": "rimraf dist cdk.out node_modules",
    "compile-canaries": "esbuild src/canaries/*.ts --log-level=warning --bundle --platform=node --outdir=dist/nodejs/node_modules --external:Synthetics --target=node22",
    "compile-lambdas": "node lib/esbuild.js",
    "compile-lambdas-old": "esbuild src/lambda/**/*.ts --log-level=warning --bundle --platform=node --outdir=dist/lambda --target=node20",
    "synth-sam": "cdk synth --no-staging > template.yaml",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1004.0",
    "@digitraffic/common": "2026.3.5-1",
    "amazon-cognito-identity-js": "6.3.16",
    "aws-cdk-lib": "2.241.0",
    "constructs": "10.5.1",
    "p-limit": "7.3.0",
    "pg-native": "3.7.0",
    "pg-promise": "12.6.2",
    "undici": "7.24.1",
    "xml2js": "0.6.2"
  },
  "devDependencies": {
    "@digitraffic-cdk/cdk-rig": "workspace:*",
    "@digitraffic-cdk/esbuild": "workspace:*",
    "@digitraffic-cdk/testing": "workspace:*",
    "@digitraffic-cdk/toolchain": "workspace:*",
    "@rushstack/heft": "1.2.6",
    "@types/aws-lambda": "8.10.161",
    "@types/node": "25.3.5",
    "@types/xml2js": "0.4.14",
    "@vitest/coverage-v8": "4.0.18",
    "aws-cdk": "3.0.0",
    "esbuild": "0.27.3",
    "parallelshell": "3.0.2",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
