{
  "name": "aton-faults",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "heft build --clean && npm run build:bundle",
    "build:bundle": "npm run compile-lambdas && npm run compile-canaries",
    "build:tsc": "heft build --clean",
    "build:watch": "heft build-watch --clean",
    "cdk": "cdk",
    "cdk-deploy-marine-prod": "../../scripts/cdk-diff-and-deploy.sh marine-prod deploy",
    "cdk-deploy-marine-test": "../../scripts/cdk-diff-and-deploy.sh marine-test deploy",
    "cdk-diff-marine-prod": "../../scripts/cdk-diff-and-deploy.sh marine-prod diff",
    "cdk-diff-marine-test": "../../scripts/cdk-diff-and-deploy.sh marine-test diff",
    "ci:test": "vitest run --reporter=junit --outputFile=test-results.xml",
    "compile-canaries": "esbuild src/canaries/*.ts --log-level=warning --bundle --platform=node --outdir=dist/nodejs/node_modules --external:Synthetics --target=node22",
    "compile-lambdas": "node lib/esbuild.js",
    "synth-sam": "cdk synth --no-staging > template.yaml",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "3.1047.0",
    "@date-fns/tz": "1.4.1",
    "@digitraffic/common": "2026.4.28-1",
    "@middy/core": "7.5.0",
    "@middy/sqs-partial-batch-failure": "7.5.0",
    "@turf/turf": "7.3.5",
    "aws-cdk-lib": "2.254.0",
    "constructs": "10.6.0",
    "date-fns": "4.1.0",
    "ky": "2.0.2",
    "parse-link-header": "2.0.0",
    "pg-native": "3.7.0",
    "pg-promise": "12.6.2",
    "spex": "4.1.0",
    "undici": "8.3.0",
    "uuid": "14.0.0",
    "wkx": "0.5.0",
    "xml2js": "0.6.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@digitraffic-cdk/cdk-rig": "workspace:*",
    "@digitraffic-cdk/esbuild": "workspace:*",
    "@digitraffic-cdk/testing": "workspace:*",
    "@digitraffic-cdk/toolchain": "workspace:*",
    "@rushstack/heft": "1.2.17",
    "@types/aws-lambda": "8.10.161",
    "@types/geojson": "7946.0.16",
    "@types/node": "24.12.2",
    "@types/xml2js": "0.4.14",
    "@vitest/coverage-v8": "4.1.6",
    "aws-cdk": "2.1122.0",
    "esbuild": "0.28.0",
    "parallelshell": "3.0.2",
    "typescript": "5.9.3",
    "vitest": "4.1.6",
    "xsd-schema-validator": "0.11.0"
  }
}
