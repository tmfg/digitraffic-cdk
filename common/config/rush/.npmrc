# Rush uses this file to configure the NPM package registry during installation.  It is applicable
# to PNPM, NPM, and Yarn package managers.  It is used by operations such as "rush install",
# "rush update", and the "install-run.js" scripts.
#
# NOTE: The "rush publish" command uses .npmrc-publish instead.
#
# Before invoking the package manager, Rush will copy this file to the folder where installation
# is performed.  The copied file will omit any config lines that reference environment variables
# that are undefined in that session; this avoids problems that would otherwise result due to
# a missing variable being replaced by an empty string.
#
# * * * SECURITY WARNING * * *
#
# It is NOT recommended to store authentication tokens in a text file on a lab machine, because
# other unrelated processes may be able to read the file.  Also, the file may persist indefinitely,
# for example if the machine loses power.  A safer practice is to pass the token via an
# environment variable, which can be referenced from .npmrc using ${} expansion.  For example:
#
#   //registry.npmjs.org/:_authToken=${NPM_AUTH_TOKEN}
#
# Note: Rush automatically copies this .npmrc to autoinstallers during "rush update-autoinstaller".
# This is built-in Rush behavior (not configurable). Unused exclusions are harmless.

# Default NPM registry - all packages without a specific scope are fetched from here
registry=https://registry.npmjs.org/

# JSR (JavaScript Registry) scoped registry configuration
# Any package with @jsr scope (e.g., @jsr/some-package) will be fetched from JSR instead of npmjs.org
# JSR is a TypeScript-native package registry: https://jsr.io
@jsr:registry=https://npm.jsr.io

# Minimum release age policy (7 days = 10080 minutes)
# Ensures packages have been published for at least 7 days before being installed
minimum-release-age=10080
ignore-scripts=true

# Internal packages - always allow latest
minimum-release-age-exclude[]=@digitraffic/common

# Security related fixes - allow specific versions immediately
# These versions might also be enforced via globalOverrides in pnpm-config.json
minimum-release-age-exclude[]=ajv@8.18.0
minimum-release-age-exclude[]=@aws-sdk/client-api-gateway@3.995.0
minimum-release-age-exclude[]=@aws-sdk/client-s3@3.995.0
minimum-release-age-exclude[]=@aws-sdk/client-secrets-manager@3.995.0
minimum-release-age-exclude[]=@aws-sdk/client-sns@3.995.0
minimum-release-age-exclude[]=@aws-sdk/client-sqs@3.995.0
minimum-release-age-exclude[]=@aws-sdk/client-ssm@3.995.0
minimum-release-age-exclude[]=@aws-sdk/client-sts@3.995.0
minimum-release-age-exclude[]=@aws-sdk/lib-storage@3.995.0
minimum-release-age-exclude[]=@aws-sdk/core@3.973.11
minimum-release-age-exclude[]=@smithy/util-defaults-mode-browser@4.3.33
minimum-release-age-exclude[]=@smithy/core@3.23.3
minimum-release-age-exclude[]=@smithy/middleware-endpoint@4.4.17
minimum-release-age-exclude[]=@smithy/smithy-client@4.11.6
minimum-release-age-exclude[]=@smithy/middleware-retry@4.4.34
minimum-release-age-exclude[]=@smithy/util-defaults-mode-node@4.2.36
minimum-release-age-exclude[]=@aws-sdk/util-endpoints@3.993.0 || 3.995.0
minimum-release-age-exclude[]=@aws-sdk/nested-clients@3.993.0
minimum-release-age-exclude[]=@aws-sdk/client-sso@3.993.0
minimum-release-age-exclude[]=@aws-sdk/token-providers@3.993.0
minimum-release-age-exclude[]=@aws-sdk/signature-v4-multi-region@3.995.0
minimum-release-age-exclude[]=@aws-sdk/middleware-user-agent@3.972.11
minimum-release-age-exclude[]=@aws-sdk/middleware-flexible-checksums@3.972.9
minimum-release-age-exclude[]=@aws-sdk/util-user-agent-node@3.972.10
minimum-release-age-exclude[]=@aws-sdk/middleware-sdk-s3@3.972.11
minimum-release-age-exclude[]=@aws-sdk/credential-provider-node@3.972.10
minimum-release-age-exclude[]=@aws-sdk/middleware-sdk-sqs@3.972.8
minimum-release-age-exclude[]=@aws-sdk/credential-provider-http@3.972.11
minimum-release-age-exclude[]=@aws-sdk/xml-builder@3.972.5
minimum-release-age-exclude[]=@aws-sdk/credential-provider-web-identity@3.972.9
minimum-release-age-exclude[]=@aws-sdk/credential-provider-env@3.972.9
minimum-release-age-exclude[]=@aws-sdk/credential-provider-process@3.972.9
minimum-release-age-exclude[]=@smithy/util-stream@4.5.13
minimum-release-age-exclude[]=@aws-sdk/credential-provider-ini@3.972.9
minimum-release-age-exclude[]=@aws-sdk/credential-provider-sso@3.972.9
minimum-release-age-exclude[]=@aws-sdk/credential-provider-login@3.972.9
# minimatch: 3.1.5, 9.0.9, 10.2.4 (GHSA-3ppc-4f35-3m26, GHSA-7r86-cg39-jmmj)
minimum-release-age-exclude[]=minimatch@3.1.5
minimum-release-age-exclude[]=minimatch@9.0.9
minimum-release-age-exclude[]=minimatch@10.2.4
# serialize-javascript: 7.0.3 (GHSA-5c6j-r48x-rmvq)
minimum-release-age-exclude[]=serialize-javascript@7.0.3
# fast-xml-parser: 5.3.8 (GHSA-fj3w-jwp8-x2g3)
minimum-release-age-exclude[]=fast-xml-parser@5.3.8

